{
  "name": "@invinite/eslint-config",
  "version": "1.0.0",
  "description": "Unified ESLint configuration for Node and React projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inviniteopen/eslint-config.git"
  },
  "type": "module",
  "main": "index.js",
  "files": [
    "index.js",
    "index.d.ts",
    "node.js",
    "node.d.ts",
    "react.js",
    "react.d.ts",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./node": {
      "types": "./node.d.ts",
      "default": "./node.js"
    },
    "./react": {
      "types": "./react.d.ts",
      "default": "./react.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint -c node.js --ignore-pattern __tests__/fixtures .",
    "lint:fix": "eslint -c node.js --ignore-pattern __tests__/fixtures . --fix",
    "format": "prettier --check --ignore-path .prettierignore .",
    "format:fix": "prettier --write --ignore-path .prettierignore .",
    "prepublishOnly": "yarn test && yarn lint && yarn format && npm pack --dry-run"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript-eslint": "^8.56.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "eslint": "^10.2.0",
    "expect-type": "^1.3.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "eslint": ">= 9"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.12.0"
}
